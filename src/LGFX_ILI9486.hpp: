#pragma once
#include <LovyanGFX.hpp>

class LGFX_ILI9486 : public lgfx::LGFX_Device {
  lgfx::Panel_ILI9486     _panel;
  lgfx::Bus_Parallel16    _bus;

public:
  LGFX_ILI9486(void) {
    {
      auto cfg = _bus.config();
      cfg.freq_write = 40000000;

      cfg.pin_wr  = 4;
      cfg.pin_rd  = 2;
      cfg.pin_rs  = 15;

      cfg.pin_d0  = 12;
      cfg.pin_d1  = 13;
      cfg.pin_d2  = 26;
      cfg.pin_d3  = 25;
      cfg.pin_d4  = 17;
      cfg.pin_d5  = 16;
      cfg.pin_d6  = 27;
      cfg.pin_d7  = 14;

      cfg.pin_d8  = 33;
      cfg.pin_d9  = 32;
      cfg.pin_d10 = 21;
      cfg.pin_d11 = 19;
      cfg.pin_d12 = 18;
      cfg.pin_d13 = 5;
      cfg.pin_d14 = 23;
      cfg.pin_d15 = 22;

      _bus.config(cfg);
    }

    {
      auto cfg = _panel.config();
      cfg.pin_cs   = 0;
      cfg.pin_rst  = 26;
      cfg.pin_busy = -1;

      cfg.panel_width  = 320;
      cfg.panel_height = 480;

      cfg.offset_x = 0;
      cfg.offset_y = 0;

      cfg.rotation = 0;

      _panel.config(cfg);
    }

    setPanel(&_panel);
    setBus(&_bus);
  }
};
